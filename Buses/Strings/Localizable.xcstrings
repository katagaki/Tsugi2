    "More.Customization.ProperText.Subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replace abbreviations in bus stop names to make bus stops easier to find."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バス停名にある略語を元の言葉にし、分かりやすくします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버스 정류장 이름의 약어를 풀어서 버스 정류장을 더 쉽게 찾을 수 있게 합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gantikan singkatan dalam nama perhentian bas untuk memudahkan pencarian."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பேருந்து நிறுத்தங்களை எளிதாகக் கண்டறிய, பேருந்து நிறுத்தப் பெயர்களில் உள்ள சுருக்கங்களை மாற்றவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แทนที่ตัวย่อในชื่อป้ายรถเมล์เพื่อให้ค้นหาป้ายรถเมล์ได้ง่ายขึ้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thay thế các chữ viết tắt trong tên trạm xe buýt để dễ tìm kiếm hơn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "公交车站名称中的缩写改为原词，使其更容易理解。"
          }
        }
      }
    },
