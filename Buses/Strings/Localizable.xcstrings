    "Nearby.Hint.NoBusStops": {
      "comment": "Nearby View",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No bus stops nearby.\nTry moving closer to a bus stop, or checking your Location Services settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くにバス停はありません。\nバス停の近くに移動する、または位置情報の設定をご確認ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "근처에 버스 정류장이 없습니다.\n버스 정류장 가까이로 이동하거나 위치 서비스 설정을 확인해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada perhentian bas berdekatan.\nCuba bergerak lebih dekat ke perhentian bas, atau semak tetapan Perkhidmatan Lokasi anda."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அருகில் பேருந்து நிறுத்தங்கள் இல்லை.\nபேருந்து நிறுத்தத்திற்கு அருகில் செல்லவும், அல்லது உங்கள் இருப்பிடச் சேவை அமைப்புகளைச் சரிபார்க்கவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีป้ายรถเมล์ใกล้เคียง\nลองเดินไปใกล้ป้ายรถเมล์มากขึ้น หรือตรวจสอบการตั้งค่าบริการตำแหน่งของคุณ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có trạm xe buýt gần đây.\nHãy thử di chuyển đến gần trạm xe buýt hơn, hoặc kiểm tra cài đặt Dịch Vụ Vị Trí của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "附近没有公交车站。\n请移动到公交车站附近或确认位置信息的设定。"
          }
        }
      }
    },
    "Nearby.Hint.NoLocation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "variations": {
            "device": {
              "iphone": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Location Services are not enabled. Select the button below to tell Buses your location without enabling Location Services."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Location Services are not enabled."
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "device": {
              "iphone": {
                "stringUnit": {
                  "state": "translated",
                  "value": "位置情報の設定が無効化されています。一時的に位置情報を共有するには、下のボタンを選択してください。"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "位置情報の設定が無効化されています。一時的に位置情報を共有するには、下のボタンを選択してください。"
                }
              }
            }
          }
        },
        "zh-Hans": {
          "variations": {
            "device": {
              "iphone": {
                "stringUnit": {
                  "state": "translated",
                  "value": "位置信息设置已禁用。暂时共享位置信息时，请点击下面的按钮。"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "位置信息设置已禁用。暂时共享位置信息时，请点击下面的按钮。"
                }
              }
            }
          }
        }
      }
    },
    "Notification.Arriving.Description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bus %1 is scheduled to arrive at %2.\nHead to the bus stop early to avoid missing the bus."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1号バスは%2に到着する予定です。\nお早めにバス停に行って、遅れないようにしましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버스 %1이(가) %2에 도착할 예정입니다.\n버스를 놓치지 않도록 일찍 정류장으로 가세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bas %1 dijadualkan tiba di %2.\nPergi ke perhentian bas awal untuk mengelakkan terlepas bas."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பேருந்து %1 %2 இல் வருவதாகத் திட்டமிடப்பட்டுள்ளது.\nபேருந்தைத் தவறவிடாமல் இருக்க, நிறுத்தத்திற்கு முன்கூட்டியே செல்லவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รถเมล์สาย %1 มีกำหนดถึง %2\nไปที่ป้ายรถเมล์ล่วงหน้าเพื่อไม่ให้พลาดรถเมล์"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xe buýt %1 dự kiến đến tại %2.\nHãy ra trạm xe buýt sớm để không bị lỡ xe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1巴士将在%2到达。\n尽快前往公共汽车停下来，以免迟到。"
          }
        }
      }
    },
    "Notification.Arriving.Title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bus Arriving at %1"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バスが%1に到着します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1에 버스 도착"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bas Tiba di %1"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "%1 இல் பேருந்து வருகிறது"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รถเมล์กำลังถึง %1"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xe Buýt Đang Đến Tại %1"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "巴士要到达%1"
          }
        }
      }
    },
    "Notification.Error": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An error occurred while setting up your notification."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知を設定する際にエラーが発生しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알림을 설정하는 중 오류가 발생했습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ralat berlaku semasa menyediakan pemberitahuan anda."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அறிவிப்பை அமைக்கும் போது பிழை ஏற்பட்டது."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เกิดข้อผิดพลาดขณะตั้งค่าการแจ้งเตือนของคุณ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã xảy ra lỗi khi thiết lập thông báo của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置通知时出错。"
          }
        }
      }
    },
    "Notification.NoPermissions": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Buses has not been granted permissions to send notifications. Please check whether Buses is allowed to send notifications in the Settings app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知を設定するには、通知の権限が必要です。設定アプリで「バス」アプリの通知権限をご確認ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Buses에 알림 전송 권한이 부여되지 않았습니다. 설정 앱에서 Buses의 알림 전송이 허용되어 있는지 확인해 주세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buses belum diberikan kebenaran untuk menghantar pemberitahuan. Sila semak sama ada Buses dibenarkan menghantar pemberitahuan dalam aplikasi Tetapan."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அறிவிப்புகளை அனுப்ப Buses க்கு அனுமதி வழங்கப்படவில்லை. அமைப்புகள் செயலியில் Buses அறிவிப்புகளை அனுப்ப அனுமதிக்கப்பட்டுள்ளதா எனச் சரிபார்க்கவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Buses ยังไม่ได้รับอนุญาตให้ส่งการแจ้งเตือน กรุณาตรวจสอบว่า Buses ได้รับอนุญาตให้ส่งการแจ้งเตือนในแอปการตั้งค่า"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Buses chưa được cấp quyền gửi thông báo. Vui lòng kiểm tra xem Buses có được phép gửi thông báo trong ứng dụng Cài Đặt không."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置通知需要通知权限。 请在设置APP中检查“巴士精灵”APP的通知权限。"
          }
        }
      }
    },
    "Notification.Set": {
      "comment": "Notifications",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You will be notified 2 minutes before this bus is scheduled to arrive."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このバスの到着予定時間の2分前に通知されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 버스가 도착 예정 시각 2분 전에 알림을 받게 됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda akan dimaklumkan 2 minit sebelum bas ini dijadualkan tiba."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்தப் பேருந்து வருவதற்கு 2 நிமிடங்களுக்கு முன் உங்களுக்கு அறிவிக்கப்படும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณจะได้รับแจ้งเตือน 2 นาทีก่อนรถเมล์คันนี้มีกำหนดถึง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn sẽ được thông báo 2 phút trước khi xe buýt này dự kiến đến."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您将在该巴士预定到达时间前2分钟收到通知。"
          }
        }
      }
    },
    "Notifications.ArrivalAlerts": {
      "comment": "Notifications View",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrival Alerts"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "到着通知"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "도착 알림"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Amaran Ketibaan"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "வருகை எச்சரிக்கைகள்"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การแจ้งเตือนการมาถึง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảnh Báo Đến Trạm"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "到达通知"
          }
        }
      }
    },
    "Notifications.ArrivalAlerts.Hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No arrival alerts set.\nTo set a new arrival alert, open a bus service's arrival information page, then tap the bell icon of the bus you want to set an arrival alert for."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予定していた到着通知はありません。\n到着通知を設定するには、バスの詳細ページを開き、乗る予定のバスの右にあるベルアイコンを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정된 도착 알림이 없습니다.\n새 도착 알림을 설정하려면 버스 서비스의 도착 정보 페이지를 열고, 알림을 설정할 버스의 종 아이콘을 탭하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada amaran ketibaan ditetapkan.\nUntuk menetapkan amaran ketibaan baharu, buka halaman maklumat ketibaan perkhidmatan bas, kemudian ketik ikon loceng bagi bas yang anda ingin tetapkan amaran."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "வருகை எச்சரிக்கைகள் எதுவும் அமைக்கப்படவில்லை.\nபுதிய வருகை எச்சரிக்கையை அமைக்க, பேருந்து சேவையின் வருகைத் தகவல் பக்கத்தைத் திறந்து, எச்சரிக்கை அமைக்க விரும்பும் பேருந்தின் மணி சின்னத்தைத் தட்டவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีการแจ้งเตือนการมาถึง\nหากต้องการตั้งการแจ้งเตือนใหม่ ให้เปิดหน้าข้อมูลการมาถึงของบริการรถเมล์ จากนั้นแตะไอคอนกระดิ่งของรถเมล์ที่ต้องการตั้งการแจ้งเตือน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa có cảnh báo đến trạm nào.\nĐể đặt cảnh báo mới, mở trang thông tin đến trạm của dịch vụ xe buýt, sau đó nhấn biểu tượng chuông của xe buýt bạn muốn đặt cảnh báo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有设置到达通知。\n要设置新到达通知，请打开总线服务的到达信息页面，然后单击要设置到达警报的总线的铃铛图标。"
          }
        }
      }
    },
