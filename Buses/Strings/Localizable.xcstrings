    "Shared.Error.InternetConnection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Internet connecction appears to be offline. Please check your Internet connection and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターネットに接続されていないようです。ネットワークを確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터넷 연결이 끊어진 것 같습니다. 인터넷 연결을 확인하고 다시 시도해 주세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sambungan Internet kelihatan terputus. Sila semak sambungan Internet anda dan cuba lagi."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இணைய இணைப்பு துண்டிக்கப்பட்டதாகத் தெரிகிறது. உங்கள் இணைய இணைப்பைச் சரிபார்த்து மீண்டும் முயற்சிக்கவும்."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเชื่อมต่ออินเทอร์เน็ตดูเหมือนจะขาดหาย กรุณาตรวจสอบการเชื่อมต่ออินเทอร์เน็ตและลองอีกครั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kết nối Internet có vẻ đang ngoại tuyến. Vui lòng kiểm tra kết nối Internet và thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接时出现问题。请确认网络后再试一次。"
          }
        }
      }
    },
